# Copy to .env and fill in real values.

# Neon Postgres (https://neon.tech). Single connection string.
#  - Locally: use the DIRECT (unpooled) string so `prisma migrate dev` works.
#  - On Vercel: use the POOLED string (host contains "-pooler") for the serverless runtime.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"

# Long random string used to sign session cookies. Generate one, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET="change-me-to-a-long-random-string"
