# Copy to .env and fill in real values.

# Neon Postgres (https://neon.tech). Two strings from the dashboard:
#   DATABASE_URL = POOLED connection (host contains "-pooler") — used by the app at runtime
#   DIRECT_URL   = DIRECT/unpooled connection — used by Prisma migrations
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"

# Long random string used to sign session cookies. Generate one, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET="change-me-to-a-long-random-string"
