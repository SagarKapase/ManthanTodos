// Manthan data model — see PRD §7
generator client {
  provider      = "prisma-client-js"
  // "native" covers local dev; the rhel target is the Vercel serverless runtime.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled connection (app runtime)
  directUrl = env("DIRECT_URL") // direct connection (migrations)
}

enum Role {
  ADMIN
  MEMBER
}

enum UserStatus {
  ACTIVE
  DEACTIVATED
}

enum Priority {
  P1
  P2
  P3
  P4
}

enum TaskStatus {
  OPEN
  COMPLETED
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

model User {
  id                 String     @id @default(cuid())
  name               String
  username           String     @unique // login identifier (username or email)
  passwordHash       String
  role               Role       @default(MEMBER)
  status             UserStatus @default(ACTIVE)
  mustChangePassword Boolean    @default(true) // first-login flow (FR-3)
  createdAt          DateTime   @default(now())

  createdTasks   Task[]         @relation("TaskCreatedBy")
  assignedTasks  Task[]         @relation("TaskAssignee")
  createdProjects Project[]     @relation("ProjectCreatedBy")
  comments       Comment[]
  notifications  Notification[]
}

model Project {
  id          String        @id @default(cuid())
  name        String
  colour      String? // optional colour tag (FR-25)
  status      ProjectStatus @default(ACTIVE)
  isInbox     Boolean       @default(false) // the default catch-all project (FR-23)
  createdById String?
  createdBy   User?         @relation("ProjectCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime      @default(now())

  tasks    Task[]
  sections Section[]
}

// Board columns within a project (Backlog / Doing / Review …). FR-34
model Section {
  id        String   @id @default(cuid())
  name      String
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  tasks Task[]
}

model Task {
  id           String     @id @default(cuid())
  title        String
  description  String?
  projectId    String
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sectionId    String?
  section      Section?   @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  assigneeId   String?
  assignee     User?      @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdById  String
  createdBy    User       @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  dueDate      DateTime?
  priority     Priority   @default(P4)
  status       TaskStatus @default(OPEN)
  parentTaskId String?
  parentTask   Task?      @relation("SubTasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subTasks     Task[]     @relation("SubTasks")
  sortOrder    Int        @default(0)
  deletedAt    DateTime? // soft delete — recoverable for a window (PRD §6.3)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  labels   Label[]
  comments Comment[]
}

model Label {
  id     String @id @default(cuid())
  name   String @unique
  colour String?
  tasks  Task[]
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  taskId    String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
